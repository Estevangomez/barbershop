
datasource db {
  provider = "postgresql"   
   
}

generator client {
  provider = "prisma-client" 
  output   = "./generated/prisma"

}

model User {
  id            String    @id @default(uuid())
  nome          String?
  email         String?   @unique
  emailVerified DateTime?
  imagem         String?  
  agendamentos      Agendamento[]
}

model Barbearia {
  id       String    @id @default(uuid())
  nome     String
  endereco  String
  imageUrl String?
  services Servico[]
  agendamentos Agendamento[]
}

model Servico {
  id           String     @id @default(uuid())
  nome         String
  preco        Decimal    @db.Decimal(10, 2)
  barbeariaId String
  barbearia   Barbearia @relation(fields: [barbeariaId], references: [id])
  descricao  String
  agendamentos     Agendamento[]
  imageUrl     String?
}

model Agendamento {
  id          String     @id @default(uuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id])
  servicoId   String
  service     Servico    @relation(fields: [servicoId], references: [id])
  barbeariaId String
  barbearia  Barbearia @relation(fields: [barbeariaId], references: [id])
  date        DateTime
}
